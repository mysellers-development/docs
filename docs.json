{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MySellers",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "css": "/custom.css",
  "navigation": {
    "products": [
      {
        "product": "MySellers AI",
        "icon": "robot",
        "tabs": [
          {
            "tab": "Documentacao",
            "groups": [
              {
                "group": "Inicio",
                "pages": ["ai/index"]
              },
              {
                "group": "Funcionalidades",
                "pages": [
                  "ai/commands",
                  "ai/scheduling",
                  "ai/handoff",
                  "ai/products",
                  "ai/media",
                  "ai/campaigns",
                  "ai/knowledge-base"
                ]
              }
            ]
          },
          {
            "tab": "Changelog",
            "pages": ["ai/changelog"]
          }
        ]
      },
      {
        "product": "MySellers API",
        "icon": "code",
        "tabs": [
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "Visao Geral",
                "pages": ["api-reference/introduction"]
              },
              {
                "group": "Leads",
                "pages": [
                  "api-reference/leads/create",
                  "api-reference/leads/list",
                  "api-reference/leads/get",
                  "api-reference/leads/update",
                  "api-reference/leads/delete",
                  "api-reference/leads/search",
                  "api-reference/leads/bulk-create",
                  "api-reference/leads/create-with-deal"
                ]
              },
              {
                "group": "Funnels",
                "pages": [
                  "api-reference/funnels/create",
                  "api-reference/funnels/list",
                  "api-reference/funnels/list-by-workspace",
                  "api-reference/funnels/get",
                  "api-reference/funnels/update",
                  "api-reference/funnels/delete",
                  "api-reference/funnels/set-default",
                  "api-reference/funnels/associate-stages",
                  "api-reference/funnels/remove-stage",
                  "api-reference/funnels/reorder-stages"
                ]
              },
              {
                "group": "Deals",
                "pages": [
                  "api-reference/deals/create",
                  "api-reference/deals/list",
                  "api-reference/deals/get",
                  "api-reference/deals/update",
                  "api-reference/deals/delete",
                  "api-reference/deals/update-stage",
                  "api-reference/deals/update-status",
                  "api-reference/deals/history",
                  "api-reference/deals/messages",
                  "api-reference/deals/list-by-funnel",
                  "api-reference/deals/list-by-lead",
                  "api-reference/deals/stats"
                ]
              },
              {
                "group": "Custom Fields",
                "pages": [
                  "api-reference/custom-fields/create",
                  "api-reference/custom-fields/list",
                  "api-reference/custom-fields/get",
                  "api-reference/custom-fields/update",
                  "api-reference/custom-fields/delete",
                  "api-reference/custom-fields/reorder"
                ]
              },
              {
                "group": "Stages",
                "pages": [
                  "api-reference/stages/create",
                  "api-reference/stages/list",
                  "api-reference/stages/get",
                  "api-reference/stages/update",
                  "api-reference/stages/delete",
                  "api-reference/stages/list-by-workspace"
                ]
              }
            ]
          }
        ]
      },
      {
        "product": "AI Tools",
        "icon": "wand-magic-sparkles",
        "tabs": [
          {
            "tab": "Ferramentas",
            "pages": ["ai-tools/claude-code", "ai-tools/cursor", "ai-tools/windsurf"]
          }
        ]
      }
